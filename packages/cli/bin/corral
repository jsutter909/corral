#!/usr/bin/env python3
# corral — spawn and manage isolated AI-agent workspaces on top of herdr.
# https://github.com/jsutter909/corral
#
# Launcher: resolves symlinks (installed as ~/.local/bin/corral), puts the
# checkout's src/ on sys.path, and hands off to the corral package. Runs
# straight from a clone — no build step, no dependencies beyond the stdlib.
import os
import sys

if sys.version_info < (3, 9):
    sys.stderr.write("error: corral needs Python 3.9 or newer\n")
    sys.exit(1)

_here = os.path.dirname(os.path.realpath(__file__))
sys.path.insert(0, os.path.join(os.path.dirname(_here), "src"))

from corral.app import main  # noqa: E402

if __name__ == "__main__":
    sys.exit(main())
