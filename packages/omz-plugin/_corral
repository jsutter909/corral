      case $cmd in            # aliases share their target's completion
        list)    cmd=ls ;;
        attach)  cmd=focus ;;
        ide)     cmd=open ;;
        clean)   cmd=prune ;;
      esac
      curcontext="${curcontext%:*:*}:corral-${cmd}:"
      case $cmd in
        spawn)
          _arguments -S \
            '(- *)'{-h,--help}'[show spawn help]' \
            '(-a --agent)'{-a,--agent}'[Agent to launch in the left pane, or "none" for a blank shell]:agent:_corral_agents' \
            '(-m --model)'{-m,--model}'[Model for the Claude agent. claude agent only]:model:(opus sonnet haiku)' \
            '(-P --permission-mode)'{-P,--permission-mode}'[Claude permission/edit mode, e.g. acceptEdits, plan. claude agent only]:mode:(acceptEdits plan bypassPermissions default)' \
            '(-p --prompt)'{-p,--prompt}'[Initial prompt to hand the agent on launch]:prompt:' \
            '(-b --base)'{-b,--base}'[Base ref to branch the worktree from]:git ref:_corral_git_refs' \
            '(-r --ratio)'{-r,--ratio}'[Agent (left) pane share of width]:ratio (0..1):' \
            '(-l --label)'{-l,--label}'[Workspace label]:label:' \
            '--no-focus[Create the workspace without switching focus to it]' \
            '--no-setup[Skip the repo'\''s .corral/setup.sh (also: CORRAL_SETUP=0)]' \
            '1:repository directory:_directories' \
            '2::new branch name:_corral_new_branch' \
            && ret=0
          ;;
        ls)
          _arguments -S \
            '(- *)'{-h,--help}'[show ls help]' \
            '(--tsv -j --json)'{-j,--json}'[Emit machine-readable JSON instead of a table]' \
            '(--json)--tsv[Emit tab-separated rows (workspace, label, repo, branch, status, worktree)]' \
            && ret=0
          ;;
        focus)
          _arguments -S \
            '(- *)'{-h,--help}'[show focus help]' \
            '1:workspace:_corral_workspaces' \
            && ret=0
          ;;
        open)
          _arguments -S \
            '(- *)'{-h,--help}'[show open help]' \
            '(-i --ide)'{-i,--ide}'[IDE to open: vscode or cursor]:ide:(vscode cursor)' \
            '(--no-ssh)--ssh[Force Remote-SSH mode (print a link that opens the IDE on]' \
            '(--ssh)--no-ssh[Force local mode (launch the IDE on this machine)]' \
            '--host[SSH host to use in the Remote-SSH link]:host:_hosts' \
            '1::workspace:_corral_workspaces' \
            && ret=0
          ;;
        close)
          _arguments -S \
            '(- *)'{-h,--help}'[show close help]' \
            '(-f --force)'{-f,--force}'[Skip the confirmation prompt; close even if .corral/cleanup.sh fails]' \
            '--no-cleanup[Do not run .corral/cleanup.sh (also: CORRAL_CLEANUP=0)]' \
            '1::workspace:_corral_workspaces' \
            && ret=0
          ;;
        prune)
          _arguments -S \
            '(- *)'{-h,--help}'[show prune help]' \
            '(-b --base)'{-b,--base}'[Branch to test "merged into" against]:git ref:_corral_git_refs' \
            '(-i --idle)'{-i,--idle}'[Also prune idle workspaces with a clean tree]' \
            '(-n --dry-run)'{-n,--dry-run}'[Show what would be pruned without removing anything]' \
            '(-f --force)'{-f,--force}'[Skip the per-workspace confirmation prompt; prune even if]' \
            '--no-cleanup[Do not run .corral/cleanup.sh (also: CORRAL_CLEANUP=0)]' \
            && ret=0
          ;;
        doctor)
          _arguments -S \
            '(- *)'{-h,--help}'[show doctor help]' \
            '--no-update[Run the checks only; never touch the installation]' \
            && ret=0
          ;;
        help)
          _arguments '1::command:_corral_commands' && ret=0
          ;;
        version)
          _message 'no more arguments'
          ;;
      esac
      ;;
  esac

  return ret
}

_corral "$@"
